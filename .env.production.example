# 对外访问端口
APP_PORT=8080

# PostgreSQL容器
POSTGRES_DB=doc_intel
POSTGRES_USER=docintel
POSTGRES_PASSWORD=请替换为高强度数据库密码

# 登录令牌签名密钥，部署前必须替换。可使用：
# python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET_KEY=请替换为至少48字符的随机字符串
AUTH_ACCESS_TOKEN_TTL_MINUTES=10080

# LLM：以下以DeepSeek为例
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=请填写DeepSeek_API_Key
# 若服务器通过代理访问模型服务，取消注释并填写
# HTTPS_PROXY=http://host.docker.internal:7890
# HTTP_PROXY=http://host.docker.internal:7890

# 智谱示例：使用时注释上面的DeepSeek配置
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-flash
# ZHIPU_API_KEY=请填写智谱_API_Key

# 本地卷存储
STORAGE_ENABLED=false
STORAGE_PROVIDER=local

# Azure Blob可选配置
# STORAGE_ENABLED=true
# STORAGE_PROVIDER=azure_blob
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER_NAME=document
# AZURE_STORAGE_BLOB_PREFIX=sessions

DEBUG=false
WORKFLOW_CHUNK_CONCURRENCY=3
